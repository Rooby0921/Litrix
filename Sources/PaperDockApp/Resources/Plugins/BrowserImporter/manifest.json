{
  "manifest_version": 3,
  "name": "Litrix Web Importer",
  "version": "1.3.0",
  "description": "Extracts paper metadata from the current web page and creates a Litrix item through the local Litrix import service.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "http://127.0.0.1:23122/*",
    "http://localhost:23122/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Litrix",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "80": "icons/icon-80.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
